{
  "name": "taskify",
  "version": "1.0.0",
  "description": "Taskify is a task management system for everyone to help you manage your tasks and projects from ideation to delivery.",
  "main": "index.js",
  "scripts": {
    "test": "jest --coverage",
    "start": "node src/app.js",
    "server": "nodemon src/app.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DSCKGEC/Taskify.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/DSCKGEC/Taskify/issues"
  },
  "homepage": "https://github.com/DSCKGEC/Taskify#readme",
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^2.0.19",
    "supertest": "^7.2.2"
  },
  "dependencies": {
    "dotenv": "^16.0.1",
    "ejs": "^3.1.8",
    "express": "^4.18.1"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/index.js",
      "!src/db/**",
      "!src/models/**",
      "!src/middleware/**",
      "!src/routes/**",
      "!src/cloudinary/**"
    ],
    "coverageReporters": ["text", "lcov", "html"],
    "coverageThreshold": {
      "global": {
        "statements": 80,
        "branches": 70,
        "functions": 80,
        "lines": 80
      }
    }
  }
}
