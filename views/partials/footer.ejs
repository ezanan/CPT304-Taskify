<!-- Enhanced Cookie Banner -->
<div
  id="cookie-banner"
  class="cookie-banner"
  role="dialog"
  aria-labelledby="cookie-title"
  aria-describedby="cookie-description"
  hidden
>
  <div class="cookie-banner-content">
    <div class="cookie-banner-text">
      <h2 id="cookie-title">Cookie preferences</h2>
      <p id="cookie-description">
        We use essential storage to make this site work. You can accept all cookies,
        reject optional cookies, or customize your preferences.
      </p>
      <a href="/privacy" class="cookie-privacy-link">Read our Privacy Policy</a>
    </div>

    <div class="cookie-banner-actions">
      <button type="button" id="cookie-accept-all" class="cookie-btn cookie-btn-primary">
        Accept all
      </button>
      <button type="button" id="cookie-reject-optional" class="cookie-btn cookie-btn-secondary">
        Reject optional
      </button>
      <button
        type="button"
        id="cookie-customize"
        class="cookie-btn cookie-btn-text"
        aria-expanded="false"
        aria-controls="cookie-preferences-panel"
      >
        Customize
      </button>
    </div>
  </div>

  <div id="cookie-preferences-panel" class="cookie-preferences-panel" hidden>
    <div class="cookie-option">
      <div>
        <strong>Essential cookies</strong>
        <p>Required for the website to work and to remember your consent choice.</p>
      </div>
      <span class="cookie-always-on">Always on</span>
    </div>

    <label class="cookie-option">
      <div>
        <strong>Preference storage</strong>
        <p>Remember optional interface preferences such as language or display choices.</p>
      </div>
      <input type="checkbox" id="cookie-pref-preferences" />
    </label>

    <label class="cookie-option">
      <div>
        <strong>Analytics preferences</strong>
        <p>Store whether anonymous usage analytics are allowed. No third-party analytics is loaded by default.</p>
      </div>
      <input type="checkbox" id="cookie-pref-analytics" />
    </label>

    <div class="cookie-preferences-actions">
      <button type="button" id="cookie-save-choices" class="cookie-btn cookie-btn-primary">
        Save choices
      </button>
    </div>
  </div>
</div>

<!-- Cookie Banner JS -->
<script>
document.addEventListener("DOMContentLoaded", function () {
  const banner = document.getElementById("cookie-banner");
  const acceptAllBtn = document.getElementById("cookie-accept-all");
  const rejectOptionalBtn = document.getElementById("cookie-reject-optional");
  const customizeBtn = document.getElementById("cookie-customize");
  const saveChoicesBtn = document.getElementById("cookie-save-choices");
  const preferencesPanel = document.getElementById("cookie-preferences-panel");
  const preferenceStorageInput = document.getElementById("cookie-pref-preferences");
  const analyticsInput = document.getElementById("cookie-pref-analytics");
  const manageCookiesBtn = document.getElementById("manage-cookies");

  const consentKey = "taskifyCookieConsent";
  const preferencesKey = "taskifyCookiePreferences";

  if (!banner) return;

  function createPreferences(optionalValue) {
    return { essential: true, preferences: optionalValue, analytics: optionalValue };
  }

  function getSavedPreferences() {
    try {
      const savedPreferences = localStorage.getItem(preferencesKey);
      return savedPreferences ? JSON.parse(savedPreferences) : createPreferences(false);
    } catch (error) {
      return createPreferences(false);
    }
  }

  function syncInputs(preferences) {
    if (preferenceStorageInput) preferenceStorageInput.checked = Boolean(preferences.preferences);
    if (analyticsInput) analyticsInput.checked = Boolean(preferences.analytics);
  }

  function showBanner() {
    syncInputs(getSavedPreferences());
    banner.hidden = false;
  }

  function hideBanner() {
    banner.hidden = true;
    if (preferencesPanel) preferencesPanel.hidden = true;
    if (customizeBtn) customizeBtn.setAttribute("aria-expanded", "false");
  }

  function saveConsent(consentStatus, preferences) {
    const normalizedPreferences = {
      essential: true,
      preferences: Boolean(preferences.preferences),
      analytics: Boolean(preferences.analytics)
    };
    localStorage.setItem(consentKey, consentStatus);
    localStorage.setItem(preferencesKey, JSON.stringify(normalizedPreferences));
    hideBanner();
  }

  const existingConsent = localStorage.getItem(consentKey);
  if (!existingConsent) showBanner();

  if (acceptAllBtn) acceptAllBtn.addEventListener("click", () => saveConsent("accepted_all", createPreferences(true)));
  if (rejectOptionalBtn) rejectOptionalBtn.addEventListener("click", () => saveConsent("rejected_optional", createPreferences(false)));

  if (customizeBtn && preferencesPanel) {
    customizeBtn.addEventListener("click", () => {
      const isExpanded = customizeBtn.getAttribute("aria-expanded") === "true";
      customizeBtn.setAttribute("aria-expanded", String(!isExpanded));
      preferencesPanel.hidden = isExpanded;
    });
  }

  if (saveChoicesBtn) {
    saveChoicesBtn.addEventListener("click", () => {
      saveConsent("customized", {
        essential: true,
        preferences: preferenceStorageInput ? preferenceStorageInput.checked : false,
        analytics: analyticsInput ? analyticsInput.checked : false
      });
    });
  }

  if (manageCookiesBtn) {
    manageCookiesBtn.addEventListener("click", () => showBanner());
  }
});
</script>